{
  "name": "sales-app-jke",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "node scripts/confirm-prod.mjs && tsc -b && vite build --mode production && npm run deploy:assets",
    "deploy:assets": "node scripts/upload-r2.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "optimize:images": "npx @frostoven/squoosh-cli --webp \"{quality:85}\" -d src/assets \"src/assets/*.jpg\" \"src/assets/*.png\"",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod": "docker-compose up -d",
    "docker:prod:build": "docker-compose up -d --build",
    "docker:prod:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:stop": "docker-compose stop",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@dicebear/collection": "^9.3.2",
    "@dicebear/core": "^9.3.2",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.1",
    "react-idle-timer": "^5.7.2",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "socket.io-msgpack-parser": "^3.0.2",
    "sonner": "^2.0.7",
    "sweetalert2": "^11.26.17",
    "sweetalert2-react-content": "^5.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "mime-types": "^3.0.2",
    "mock-socket": "^9.3.1",
    "msw": "^2.12.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.2",
    "vitest-websocket-mock": "^0.5.0"
  }
}
